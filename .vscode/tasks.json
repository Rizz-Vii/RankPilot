{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "emulator:firestore:bg",
      "type": "shell",
      "command": "npx firebase emulators:start --only firestore",
      "isBackground": true,
      "problemMatcher": {
        "owner": "firestore-emulator",
        "pattern": { "regexp": "." },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting.*Emulator|.* emulators:start",
          "endsPattern": ".*Firestore Emulator running|.*All emulators ready|.*ui .* Running"
        }
      },
      "group": "build"
    },
    {
      "label": "dev-server",
      "type": "shell",
      "command": "npm run dev-no-turbopack",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^(?:.*ready - started server on|.*Starting local development server)",
          "endsPattern": "^(?:.*ready - Local|.*ready - on http|.*Compiled successfully)"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "typecheck",
      "type": "shell",
      "command": "npm run typecheck",
      "problemMatcher": "$tsc"
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "npm run lint:flat:all",
      "problemMatcher": [
        "$eslint-stylish"
      ]
    },
    {
      "label": "lint:fix",
      "type": "shell",
      "command": "npm run lint:fix",
      "problemMatcher": [
        "$eslint-stylish"
      ]
    },
    {
      "label": "build",
      "type": "shell",
      "command": "npm run build",
      "problemMatcher": "$tsc",
      "group": "build"
    },
    {
      "label": "tests:unit-fast",
      "type": "shell",
      "command": "npm run test:unit",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "tests:provenance",
      "type": "shell",
      "command": "npm run test:provenance-audit"
    },
    {
      "label": "verify-fast",
      "dependsOrder": "sequence",
      "dependsOn": [
        "typecheck",
        "lint",
        "build"
      ]
    },
    {
      "label": "quality:fast",
      "type": "shell",
      "command": "npm run quality:fast"
    },
    {
      "label": "quality:full",
      "type": "shell",
      "command": "npm run quality:full"
    },
    {
      "label": "aider:prep",
      "type": "shell",
      "command": "npm run ai:aider:prep",
      "problemMatcher": []
    },
    {
      "label": "delegation:enqueue",
      "type": "shell",
      "command": "npm run delegate:enqueue",
      "problemMatcher": []
    },
    {
      "label": "delegation:process",
      "type": "shell",
      "command": "npm run delegate:process",
      "problemMatcher": []
    },
    {
      "label": "delegation:auto",
      "type": "shell",
      "command": "cross-env AIDER_AUTORUN=1 npm run delegate:process",
      "isBackground": true,
      "problemMatcher": {
        "owner": "delegation",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Starting delegation processing",
          "endsPattern": "^Delegation queue idle"
        }
      }
    },
    {
      "label": "codex:brain:auto",
      "type": "shell",
      "command": "npm run brain:auto",
      "problemMatcher": []
    },
    {
      "label": "codex:brain:plan",
      "type": "shell",
      "command": "npm run brain:plan-only",
      "problemMatcher": []
    },
    {
      "label": "codex:brain:execute",
      "type": "shell",
      "command": "npm run brain:execute",
      "problemMatcher": []
    },
    {
      "label": "eslint:autofix-all",
      "type": "shell",
      "command": "npm run eslint:autofix-all",
      "problemMatcher": [
        "$eslint-stylish"
      ]
    },
    {
      "label": "lint:report:json",
      "type": "shell",
      "command": "npm run lint:report:json",
      "problemMatcher": []
    },
    {
      "label": "refactor:lint-sweep",
      "dependsOrder": "sequence",
      "dependsOn": [
        "eslint:autofix-all",
        "lint:report:json",
        "quality:fast"
      ]
    },
    {
      "label": "delegation:loop",
      "type": "shell",
      "command": "npm run delegate:loop",
      "isBackground": true,
      "problemMatcher": {
        "owner": "delegation-loop",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[delegate:loop] queue snapshot",
          "endsPattern": "^$"
        }
      }
    },
    {
      "label": "two-agent:plan-loop",
      "type": "shell",
      "command": "npm run brain:two-agent:plan-loop",
      "isBackground": true,
      "problemMatcher": {
        "owner": "two-agent-plan-loop",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[two-agent:plan-loop] start",
          "endsPattern": "^\\[two-agent:plan-loop] finished"
        }
      }
    },
    {
      "label": "delegation:triggered-runner",
      "type": "shell",
      "command": "npm run delegate:triggered-runner",
      "isBackground": true,
      "problemMatcher": {
        "owner": "delegation-triggered-runner",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[triggered-runner] watching",
          "endsPattern": "^$"
        }
      }
    },
    {
      "label": "aider:concurrent-loop",
      "type": "shell",
      "command": "npm run aider:concurrent-loop",
      "isBackground": true,
      "problemMatcher": {
        "owner": "aider-concurrent-loop",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[aider:loop",
          "endsPattern": "^$"
        }
      }
    },
    {
      "label": "codex:concurrent-loop",
      "type": "shell",
      "command": "cross-env CODEX_SELECTIVE=1 npm run codex:loop",
      "isBackground": true,
      "problemMatcher": {
        "owner": "codex-concurrent-loop",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[codex:loop",
          "endsPattern": "^$"
        }
      }
    },
    {
      "label": "two-agent:unified-suite",
      "type": "shell",
      "command": "bash scripts/run-two-agent-suite.sh",
      "problemMatcher": [],
      "detail": "Starts aider & codex concurrent loops + delegation + triggered runner then runs planner loop"
    }
  ]
}
