{
  "compilerOptions": {
    "noEmit": true,
    "module": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "lib": ["es2022", "dom"],
    "baseUrl": "../",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "**/*.spec.ts",
    "**/*.test.ts",
    "../playwright.config.ts",
    "../playwright.config.*.ts"
  ],
  "exclude": ["node_modules", "dist", "build", "lib"]
}
