{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["es2022", "dom"],
    "baseUrl": ".",
    "outDir": "lib",
    "sourceMap": true,
    "composite": true,
    "declaration": false,
    "emitDeclarationOnly": false
  },
  "compileOnSave": true,
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "lib", "dist", "build"]
}
