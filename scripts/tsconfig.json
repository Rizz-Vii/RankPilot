{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "baseUrl": "..",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "./**/*.ts",
    "../src/**/*.ts",
    "../src/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "build", "lib"]
}
