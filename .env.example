###############################################
# RankPilot Environment Example (NO SECRETS)  #
# Copy to .env.local and fill real values.    #
###############################################

# Core
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_me_dev_secret

# Auth / Email (placeholders)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASS=app_password_here
CONTACT_FROM_EMAIL=you@example.com
CONTACT_RECEIVER_EMAIL=you@example.com

# Stripe (test)
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_AGENCY=price_agency_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder

# OpenAI / AI Providers
OPENAI_API_KEY=sk-openai-placeholder
OPENAI_GPT5_KEY=sk-openai-gpt5-placeholder
OPENAI_ORGANIZATION=org_placeholder
GEMINI_API_KEY=gemini_key_placeholder
GOOGLE_API_KEY=google_api_key_placeholder
HUGGINGFACE_TOKEN=hf_placeholder

# GitHub PAT (read-only scopes suggested: repo:read, contents:read)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_placeholder

# Firecrawl / Zapier / Brave
FIRECRAWL_API_KEY=firecrawl_placeholder
ZAPIER_API_KEY=zapier_placeholder
BRAVE_API_KEY=brave_placeholder

# Sentry (public DSN ok; auth token only in local env)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=replace_in_local_only
SENTRY_ORG=your_org
SENTRY_PROJECT=your_project
SENTRY_URL=https://sentry.io
SENTRY_CLIENT_ID=client_id_placeholder
SENTRY_CLIENT_SECRET=client_secret_placeholder

# Firebase (public web config)
NEXT_PUBLIC_FIREBASE_API_KEY=firebase_public_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Feature Flags (examples)
RANKPILOT_AGENTS_ENABLED=false
NEUROSEO_ORCHESTRATOR_ENABLED=true
NEXT_PUBLIC_ENABLE_PWA=false

# reCAPTCHA (required in firebase.json frameworksBackend secrets)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=recaptcha_site_key_placeholder
RECAPTCHA_SECRET_KEY=recaptcha_secret_placeholder

# Optional Web Push VAPID public key for PWA notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=vapid_public_key_placeholder

# Optional Performance
NODE_OPTIONS=--max-old-space-size=3072

# Twilio (Voice) & Base URL for callbacks
# PUBLIC_BASE_URL is used for external callbacks (e.g., Twilio status webhooks)
PUBLIC_BASE_URL=http://localhost:3000
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=twilio_auth_token_placeholder
TWILIO_FROM_NUMBER=+15555550123  # E.164 format

# Add additional placeholders below
