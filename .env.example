# 🚀 RankPilot Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit files with real API keys to version control

# ==============================================
# DEVELOPMENT ENVIRONMENT
# ==============================================
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# ==============================================
# APPLICATION URLs
# ==============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api
NEXTAUTH_URL=http://localhost:3000

# ==============================================
# FIREBASE CONFIGURATION
# ==============================================
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin (for server-side operations)
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_PRIVATE_KEY=your-private-key
FIREBASE_ADMIN_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# ==============================================
# AI API KEYS
# ==============================================
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-google-api-key

# ==============================================
# THIRD-PARTY SERVICES
# ==============================================
# Firecrawl (Web scraping)
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ==============================================
# MCP SERVER INTEGRATION
# ==============================================
# Add your MCP server configuration here
MCP_SERVER_URL=your-mcp-server-url
MCP_API_KEY=your-mcp-api-key

# ==============================================
# TESTING & DEVELOPMENT
# ==============================================
# Test user credentials (for automated testing)
TEST_ADMIN_USERNAME=test-admin
TEST_ADMIN_PASSWORD=secure-test-password
TEST_USER_USERNAME=test-user
TEST_USER_PASSWORD=secure-test-password
