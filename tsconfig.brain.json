{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2019",
    "rootDir": ".",
    "outDir": "dist/brain",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "noImplicitAny": false,
    "strict": false,
    "types": ["node"]
  },
  "include": ["scripts/brain/**/*.ts", "types/brain.ts"],
  "exclude": ["node_modules", "dist", "src", "functions", "testing"]
}

