{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2019",
    "rootDir": ".",
    "outDir": "dist/brain",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2019"],
    "moduleResolution": "node"
  },
  "include": ["scripts/brain/**/*.ts", "types/**/*.ts"]
}

