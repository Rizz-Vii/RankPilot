{
  "hosting": {
    "source": ".",
    "site": "rankpilot-production",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "frameworksBackend": {
      "region": "australia-southeast2",
      "secrets": [
        "GEMINI_API_KEY",
        "GOOGLE_API_KEY",
        "OPENAI_API_KEY",
        "FIRECRAWL_API_KEY",
        "NEXT_PUBLIC_RECAPTCHA_SITE_KEY",
        "RECAPTCHA_SECRET_KEY",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "SENTRY_DSN",
        "CRAWL_PROBE_TOKEN",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_USER",
        "SMTP_PASS",
        "CONTACT_FROM_EMAIL",
        "CONTACT_RECEIVER_EMAIL"
      ]
    },
    "headers": [
      {
        "source": "/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          },
          {
            "key": "Vary",
            "value": "Accept-Encoding"
          }
        ]
      },
      {
        "source": "/_next/data/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "private, no-store"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "region": "australia-southeast1"
  }
}
