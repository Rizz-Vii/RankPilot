{
    "compilerOptions": {
        "target": "ES2022",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "useUnknownInCatchVariables": true,
        "noImplicitOverride": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    }
}
