{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      // Help TS language service resolve Stripe types under Bundler resolution
      "stripe": [
        "./node_modules/stripe/types/index.d.ts"
      ]
    },
    "verbatimModuleSyntax": true,
    "typeRoots": [
      "./node_modules/@types",
      "./types"
    ],
    "types": [
      "node",
      "next",
      "mocha",
      "chai"
    ]
  },
  "include": [
    "middleware.ts",
    "next-env.d.ts",
    "playwright.config.*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
  "src/app/.well-known/**/*.ts",
    "testing/**/*.ts",
    "testing/**/*.tsx",
    "types/**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "backups/**/*",
    ".typescript-guardian-backups/**/*",
    "docs-backup-*/**/*",
    "dist",
    "build",
    "lib"
  ]
}
