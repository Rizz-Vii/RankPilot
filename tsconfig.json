{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "verbatimModuleSyntax": true
  },
  "include": [
    "next-env.d.ts",
    "middleware.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "playwright.config.*.ts",
    "types/**/*.d.ts",
    "testing/**/*.ts",
    "testing/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "backups/**/*",
    ".typescript-guardian-backups/**/*",
    "docs-backup-*/**/*",
    "dist",
    "build",
    "lib"
  ]
}
