{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "verbatimModuleSyntax": true
  },
  "include": [
    "middleware.ts",
    "next-env.d.ts",
    "playwright.config.*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "testing/**/*.ts",
    "testing/**/*.tsx",
    "types/**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "backups/**/*",
    ".typescript-guardian-backups/**/*",
    "docs-backup-*/**/*",
    "dist",
    "build",
    "lib"
  ]
}
